{
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "candidate-route": {
        "ClusterId": "candidate-cluster",
        "Match": {
          "Path": "/api/candidates/{**catch-all}"
        }
      },
      "assessment-route": {
        "ClusterId": "assessment-cluster",
        "Match": {
          "Path": "/api/assessments/{**catch-all}"
        }
      },
      "assessment-hub-route": {
        "ClusterId": "assessment-cluster",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      },
      "answer-route": {
        "ClusterId": "answer-cluster",
        "Match": {
          "Path": "/api/answers/{**catch-all}"
        }
      },
      "result-route": {
        "ClusterId": "result-cluster",
        "Match": {
          "Path": "/api/results/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-service": {
            "Address": "https://localhost:7140/"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        }
      },
      "candidate-cluster": {
        "Destinations": {
          "candidate-service": {
            "Address": "https://localhost:7146/"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        }
      },
      "assessment-cluster": {
        "Destinations": {
          "assessment-service": {
            "Address": "https://localhost:7228/"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        }
      },
      "answer-cluster": {
        "Destinations": {
          "answer-service": {
            "Address": "https://localhost:7252/"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        }
      },
      "result-cluster": {
        "Destinations": {
          "result-service": {
            "Address": "https://localhost:7217/"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*"
}
